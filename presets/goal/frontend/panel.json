{
  "$schema": "../../../schemas/task-preset-plugin/panel.schema.json",
  "surface": "drawer",
  "title": {
    "key": "taskPreset.title"
  },
  "description": {
    "key": "taskPreset.description"
  },
  "defaultTitle": {
    "key": "taskPreset.defaultTitle"
  },
  "submitLabel": {
    "key": "taskPreset.submit"
  },
  "submittingLabel": {
    "key": "taskPreset.submitting"
  },
  "sections": [
    {
      "id": "context",
      "layout": "split",
      "fields": [
        {
          "id": "projectId",
          "renderer": "project-picker",
          "label": {
            "key": "panel.projectLabel"
          },
          "hint": {
            "key": "panel.projectHint"
          },
          "required": true,
          "output": "projectId"
        },
        {
          "id": "title",
          "renderer": "text",
          "label": {
            "key": "panel.taskNameLabel"
          },
          "hint": {
            "key": "panel.taskNameHint"
          },
          "placeholder": {
            "key": "panel.taskNamePlaceholder"
          },
          "output": "title"
        },
        {
          "id": "targetRepositories",
          "renderer": "repository-access-selector",
          "label": {
            "key": "panel.repositoryAccessLabel"
          },
          "hint": {
            "key": "panel.repositoryAccessHint"
          },
          "output": "targetRepositories",
          "selectionMode": "multiple",
          "componentProps": {
            "targetSelectionId": "targetRepositories",
            "emptyTextKey": "panel.repositoryAccessEmpty"
          }
        }
      ]
    },
    {
      "id": "goal-task",
      "layout": "stack",
      "fields": [
        {
          "id": "goalCommandIds",
          "renderer": "command-picker",
          "label": {
            "key": "panel.commandLabel"
          },
          "hint": {
            "key": "panel.commandHint"
          },
          "required": true,
          "output": "goalCommandIds",
          "selectionMode": "single",
          "dataSource": "./commands.json"
        },
        {
          "id": "goalDescription",
          "renderer": "multiline-text",
          "inputType": "haginput",
          "label": {
            "key": "panel.goalLabel"
          },
          "hint": {
            "key": "panel.goalHint"
          },
          "placeholder": {
            "key": "panel.goalPlaceholder"
          },
          "required": true,
          "output": "goalDescription"
        }
      ]
    }
  ]
}
