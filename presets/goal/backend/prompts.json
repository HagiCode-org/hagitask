{
  "$schema": "../../../schemas/task-preset-plugin/prompt-package.schema.json",
  "version": "1.1.0",
  "templateEngine": "handlebars",
  "defaultLocale": "en-US",
  "supportedLocales": [
    "en-US",
    "zh-CN"
  ],
  "inputs": [
    {
      "name": "projectPath",
      "source": "system",
      "required": true,
      "description": "Absolute path to the selected project root."
    },
    {
      "name": "repositoryPath",
      "source": "computed-context",
      "description": "Resolved repository identity hint for the selected project."
    },
    {
      "name": "goalCommandIds",
      "source": "task-preset-input",
      "required": true,
      "description": "Selected bundled goal command id."
    },
    {
      "name": "goalDescription",
      "source": "task-preset-input",
      "required": true,
      "description": "Required sustained-work objective entered by the user."
    },
    {
      "name": "targetScopeMarkdown",
      "source": "task-preset-input",
      "description": "Optional markdown block describing selected writable and read-only repositories."
    },
    {
      "name": "targetRepositories",
      "source": "computed-context",
      "description": "Optional selected repositories resolved from the preset task scope."
    }
  ],
  "rendering": {
    "strictVariables": false,
    "trimBlocks": true
  },
  "variants": {
    "selectors": [
      "agent",
      "language"
    ],
    "entries": [
      {
        "id": "native-en-us",
        "match": {
          "agent": [
            "claude",
            "codex"
          ],
          "language": [
            "en-US"
          ]
        },
        "systemTemplate": "./templates/en-US/native.system.md",
        "userTemplate": "./templates/en-US/native.user.hbs"
      },
      {
        "id": "native-zh-cn",
        "match": {
          "agent": [
            "claude",
            "codex"
          ],
          "language": [
            "zh-CN"
          ]
        },
        "systemTemplate": "./templates/zh-CN/native.system.md",
        "userTemplate": "./templates/zh-CN/native.user.hbs"
      },
      {
        "id": "fallback-en-us",
        "match": {
          "language": [
            "en-US"
          ]
        },
        "systemTemplate": "./templates/en-US/fallback.system.md",
        "userTemplate": "./templates/en-US/fallback.user.hbs"
      },
      {
        "id": "fallback-zh-cn",
        "match": {
          "language": [
            "zh-CN"
          ]
        },
        "systemTemplate": "./templates/zh-CN/fallback.system.md",
        "userTemplate": "./templates/zh-CN/fallback.user.hbs"
      }
    ],
    "fallback": {
      "id": "fallback-default",
      "systemTemplate": "./templates/en-US/fallback.system.md",
      "userTemplate": "./templates/en-US/fallback.user.hbs"
    }
  }
}
