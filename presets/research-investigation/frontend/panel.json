{
  "$schema": "../../../schemas/task-preset-plugin/panel.schema.json",
  "surface": "drawer",
  "title": {
    "key": "taskPreset.title"
  },
  "description": {
    "key": "taskPreset.description"
  },
  "defaultTitle": {
    "key": "taskPreset.defaultTitle"
  },
  "submitLabel": {
    "key": "taskPreset.submit"
  },
  "submittingLabel": {
    "key": "taskPreset.submitting"
  },
  "sections": [
    {
      "id": "context",
      "layout": "split",
      "fields": [
        {
          "id": "projectId",
          "renderer": "project-picker",
          "label": {
            "key": "panel.projectLabel"
          },
          "hint": {
            "key": "panel.projectHint"
          },
          "required": true,
          "output": "projectId"
        },
        {
          "id": "title",
          "renderer": "text",
          "label": {
            "key": "panel.taskNameLabel"
          },
          "hint": {
            "key": "panel.taskNameHint"
          },
          "placeholder": {
            "key": "panel.taskNamePlaceholder"
          },
          "output": "title"
        },
        {
          "id": "outputVaultId",
          "renderer": "vault-role-selector",
          "inputType": "text",
          "label": {
            "key": "panel.vaultScopeLabel"
          },
          "hint": {
            "key": "panel.vaultScopeHint"
          },
          "required": true,
          "output": "outputVaultId",
          "componentProps": {
            "allowOutputSelection": true,
            "requireOutputSelection": true,
            "emptyTitleKey": "panel.vaultEmptyTitle",
            "emptyDescriptionKey": "panel.vaultEmptyDescription",
            "requiredMessageKey": "panel.vaultRequiredMessage"
          }
        },
        {
          "id": "targetProjects",
          "renderer": "project-reference-selector",
          "inputType": "text",
          "label": {
            "key": "panel.projectReferencesLabel"
          },
          "hint": {
            "key": "panel.projectReferencesHint"
          },
          "required": false,
          "output": "targetProjects",
          "selectionMode": "multiple"
        }
      ]
    },
    {
      "id": "research-task",
      "layout": "stack",
      "fields": [
        {
          "id": "repositoryUrls",
          "renderer": "multiline-text",
          "inputType": "text",
          "label": {
            "key": "panel.repositoryUrlsLabel"
          },
          "hint": {
            "key": "panel.repositoryUrlsHint"
          },
          "placeholder": {
            "key": "panel.repositoryUrlsPlaceholder"
          },
          "required": false,
          "output": "repositoryUrls"
        },
        {
          "id": "researchDirection",
          "renderer": "multiline-text",
          "inputType": "haginput",
          "label": {
            "key": "panel.directionLabel"
          },
          "hint": {
            "key": "panel.directionHint"
          },
          "placeholder": {
            "key": "panel.directionPlaceholder"
          },
          "required": true,
          "output": "researchDirection",
          "componentProps": {
            "requiredMessageKey": "panel.directionRequiredMessage"
          }
        }
      ]
    }
  ]
}
