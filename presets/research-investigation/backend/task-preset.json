{
  "$schema": "../../../schemas/task-preset-plugin/task-preset.schema.json",
  "taskKey": "researchInvestigation",
  "scriptKey": "autotask.research-investigation",
  "defaultTargetType": "vault",
  "requirements": [
    {
      "type": "agent",
      "name": "any"
    }
  ],
  "targets": {
    "repositories": {
      "enabled": false
    },
    "vaults": {
      "enabled": false
    },
    "projects": {
      "enabled": false
    }
  },
  "inputBindings": [
    {
      "input": "researchDirection",
      "promptParameter": "researchDirection",
      "metadataKey": "autoTaskResearchDirection",
      "required": true
    },
    {
      "input": "repositoryUrls",
      "promptParameter": "repositoryUrls",
      "metadataKey": "autoTaskResearchRepositoryUrls"
    }
  ]
}
