{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hagicode.local/designs/task-preset-plugin-schemas/prompt-package.schema.json",
  "title": "Task Preset Plugin Prompt Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "templateEngine",
    "defaultLocale",
    "supportedLocales",
    "inputs"
  ],
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "locales"
          ]
        },
        {
          "required": [
            "variants"
          ]
        }
      ]
    }
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "templateEngine": {
      "type": "string",
      "enum": [
        "handlebars"
      ]
    },
    "defaultLocale": {
      "type": "string"
    },
    "supportedLocales": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input"
      }
    },
    "partials": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "rendering": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strictVariables": {
          "type": "boolean"
        },
        "trimBlocks": {
          "type": "boolean"
        }
      }
    },
    "locales": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/localePrompt"
      }
    },
    "variants": {
      "$ref": "#/$defs/variants"
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "task-preset-input",
            "session-metadata",
            "computed-context",
            "system"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "localePrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "systemTemplate",
        "userTemplate"
      ],
      "properties": {
        "systemTemplate": {
          "type": "string"
        },
        "developerTemplate": {
          "type": "string"
        },
        "userTemplate": {
          "type": "string"
        },
        "outputSchema": {
          "type": "string"
        }
      }
    },
    "selectorName": {
      "type": "string",
      "enum": [
        "agent",
        "language"
      ]
    },
    "selectorValues": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "variantMatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "agent": {
          "$ref": "#/$defs/selectorValues"
        },
        "language": {
          "$ref": "#/$defs/selectorValues"
        }
      }
    },
    "variantTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "systemTemplate",
        "userTemplate"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "systemTemplate": {
          "type": "string"
        },
        "userTemplate": {
          "type": "string"
        }
      }
    },
    "variantEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/variantTemplate"
        },
        {
          "type": "object",
          "required": [
            "match"
          ],
          "properties": {
            "match": {
              "$ref": "#/$defs/variantMatch"
            }
          }
        }
      ]
    },
    "variants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selectors",
        "entries",
        "fallback"
      ],
      "properties": {
        "selectors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/selectorName"
          }
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/variantEntry"
          }
        },
        "fallback": {
          "$ref": "#/$defs/variantTemplate"
        }
      }
    }
  }
}
