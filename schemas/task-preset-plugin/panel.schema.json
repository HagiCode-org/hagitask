{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hagicode.local/designs/task-preset-plugin-schemas/panel.schema.json",
  "title": "Task Preset Plugin Panel Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface",
    "title",
    "description",
    "defaultTitle",
    "submitLabel",
    "sections"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "surface": {
      "type": "string",
      "enum": [
        "drawer",
        "dialog",
        "page"
      ]
    },
    "title": {
      "$ref": "#/$defs/localizedKey"
    },
    "description": {
      "$ref": "#/$defs/localizedKey"
    },
    "defaultTitle": {
      "$ref": "#/$defs/localizedKey"
    },
    "submitLabel": {
      "$ref": "#/$defs/localizedKey"
    },
    "submittingLabel": {
      "$ref": "#/$defs/localizedKey"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "layout",
        "fields"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "$ref": "#/$defs/localizedKey"
        },
        "description": {
          "$ref": "#/$defs/localizedKey"
        },
        "layout": {
          "type": "string",
          "enum": [
            "stack",
            "split",
            "sidebar"
          ]
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "renderer",
        "output"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "renderer": {
          "type": "string"
        },
        "label": {
          "$ref": "#/$defs/localizedKey"
        },
        "hint": {
          "$ref": "#/$defs/localizedKey"
        },
        "placeholder": {
          "$ref": "#/$defs/localizedKey"
        },
        "required": {
          "type": "boolean"
        },
        "output": {
          "type": "string"
        },
        "selectionMode": {
          "type": "string",
          "enum": [
            "single",
            "multiple"
          ]
        },
        "dataSource": {
          "type": "string"
        },
        "componentProps": {
          "type": "object",
          "properties": {
            "targetSelectionId": {
              "type": "string"
            },
            "emptyTextKey": {
              "type": "string"
            },
            "role": {
              "type": "string"
            },
            "vaultType": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "localizedKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key"
      ],
      "properties": {
        "key": {
          "type": "string"
        }
      }
    }
  }
}
