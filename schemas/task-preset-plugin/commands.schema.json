{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hagicode.local/designs/task-preset-plugin-schemas/commands.schema.json",
  "title": "Task Preset Plugin Command Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selectionMode",
    "groups",
    "commands"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.1"
    },
    "selectionMode": {
      "type": "string",
      "enum": [
        "single",
        "multiple"
      ]
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseUrl": {
          "type": "string"
        },
        "routeTemplate": {
          "type": "string"
        },
        "languageResolver": {
          "type": "string"
        }
      }
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command"
      }
    }
  },
  "$defs": {
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "$ref": "#/$defs/localizedKey"
        },
        "description": {
          "$ref": "#/$defs/localizedKey"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "groupId",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "groupId": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "skill": {
          "type": "string"
        },
        "description": {
          "$ref": "#/$defs/localizedKey"
        },
        "docsSlug": {
          "type": "string"
        },
        "preludeTemplate": {
          "type": "string"
        }
      }
    },
    "localizedKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key"
      ],
      "properties": {
        "key": {
          "type": "string"
        }
      }
    }
  }
}
